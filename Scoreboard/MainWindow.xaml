                                <Button Style="{StaticResource StandardButton}" Name="btnEditCommand" Height="24" Width="24" Content="..." FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0 68 0 0" Click="EditCommand" IsEnabled="false" Cursor="Hand" />
                                <Button Style="{StaticResource StandardButton}" Name="btnApplyCommand" Width="120" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0 124 0 0" Content="Apply" FontSize="14" Click="BtnApplyCommand_Click" IsEnabled="False" Cursor="Hand" />
                            </Grid>

                            <Grid Width="368" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="192 24 0 0">
                                <Label Content="Name" Height="24" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="0" FontSize="14" VerticalContentAlignment="Bottom" FontWeight="Bold"/>
                                <TextBox Name="tbCommandName" Height="24" Margin="0 24 0 0" VerticalAlignment="Top" VerticalContentAlignment="Center" FontSize="16" TextChanged="tbCommandName_TextChanged"/>
                                <Label Content="Value" Height="24" Margin="0 52 0 0" VerticalAlignment="Top" HorizontalAlignment="Left" Padding="0" FontSize="14" VerticalContentAlignment="Bottom" FontWeight="Bold"/>
                                <TextBox Name="tbCommandValue" Height="24" Margin="0 76 0 0" VerticalAlignment="Top" PreviewKeyDown="tbCommandValue_PreviewKeyDown" KeyDown="tbCommandValue_KeyDown" VerticalContentAlignment="Center" TextChanged="tbCommandValue_TextChanged" FontSize="16" />
                                <Label Content="*alt, shift and ctrl plus an additional key (number, letter or F keys)*" Height="16" Margin="0,101,0,0" VerticalAlignment="Top" HorizontalAlignment="Center" Padding="0" FontSize="12" VerticalContentAlignment="Top" />
                                <Button Style="{DynamicResource SaveButton}" Name="btnSaveCommand" Height="28" Width="100" Margin="0 132 0 0" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Add" FontSize="14" Cursor="Hand" Click="SaveCommand" IsEnabled="False" IsDefault="True" />
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Name="settingsTab" Header="Settings" FontSize="14">
                    <Grid Width="576" Cursor="Arrow">
                        <Label Name="lbOutputFolder" Content="Output folder" Height="24" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8" FontSize="14" Padding="0" VerticalContentAlignment="Center" FontWeight="Bold"/>
                        <TextBox Name="tbOutputFolder" IsEnabled="False" Width="230" Height="24" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8 32 0 0" VerticalContentAlignment="Center" TextChanged="SettingsTextChanged"/>
                        <Button Style="{StaticResource StandardButton}" Name="btnOutputFolder" Width="30" Height="24" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="246 32 0 0" Content="..." FontSize="14" VerticalContentAlignment="Center" Click="BrowseOutput" Cursor="Hand"/>
                        <Label Name="lbSaveMessage" Content="Changes saved!" Height="32" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="124 8" FontSize="14" Padding="0" VerticalContentAlignment="Center" Foreground="Green" Visibility="Hidden"/>
                        <Button Style="{StaticResource StandardButton}" Name="btnSaveSettings" Width="100" Height="32" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8 216 8 8" Content="Save settings" FontSize="14" VerticalContentAlignment="Center" Click="SaveSettings" Cursor="Hand" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
        <Label Name="lbGithub" Width="118" HorizontalAlignment="Left" VerticalAlignment="Bottom" FontStyle="Italic" FontFamily="Calibri" FontSize="13" Margin="466 0 0 0">
            <Hyperlink NavigateUri="http://github.com/jmmdev" RequestNavigate="Hyperlink_RequestNavigate">
                github.com/jmmdev
            </Hyperlink>
        </Label>
    </Grid>
</Window>
